{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "productName",
      "inTransit"
    ],
    "properties": {
      "productName": {
        "bsonType": "string"
      },
      "atcCode": {
        "bsonType": "string"
      },
      "coldChain": {
        "bsonType": "bool"
      },
      "unitWeight": {
        "bsonType": [
          "double",
          "decimal"
        ]
      },
      "batchId": {
        "bsonType": "objectId"
      },
      "createdAt": {
        "bsonType": "date"
      },
      "inTransit": {
        "bsonType": "bool"
      },
      "location": {
        "bsonType": "object",
        "properties": {
          "type": {
            "bsonType": "string",
            "enum": [
              "manufacturer",
              "distributor",
              "retailer"
            ]
          },
          "id": {
            "bsonType": "objectId"
          }
        }
      }
    }
  }
}